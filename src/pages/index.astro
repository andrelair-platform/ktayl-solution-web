---
import Layout from '../layouts/Layout.astro';
import { lobs } from '../data/lob';
---

<Layout title="Specialty Insurance Consulting" description="ktayl-solution — Specialty insurance consulting and risk advisory for complex global risks across marine, aviation, property, liability, financial lines, energy and cyber.">

  <!-- HERO -->
  <section
    class="relative min-h-screen flex flex-col justify-center overflow-hidden"
    style="background: linear-gradient(135deg, #00233A 0%, #00375A 60%, #004D7A 100%);"
  >
    <div class="absolute inset-0 opacity-5" style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E\");"></div>
    <div class="absolute top-0 left-0 right-0 h-1 bg-[#E8690B]"></div>

    <div class="relative max-w-7xl mx-auto px-6 pt-32 pb-24">
      <div class="max-w-3xl">
        <span class="section-label">Partner in Risk</span>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-tight mb-6">
          Specialty Insurance<br />
          <span style="color:#E8690B;">Consulting</span> for<br />
          Complex Risks
        </h1>
        <p class="text-xl text-slate-300 leading-relaxed mb-10 max-w-2xl">
          ktayl-solution provides independent advisory across seven lines of business — from marine cargo to cyber risk. We place complex programmes in Lloyd's, European, and international specialty markets.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/#lob" class="btn-primary">Explore Our Lines</a>
          <a href="/#contact" class="btn-outline">Speak to an Advisor</a>
        </div>
      </div>

      <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { value: '7', label: 'Lines of Business' },
          { value: '15+', label: 'Years of Expertise' },
          { value: '30+', label: 'Markets & Syndicates' },
          { value: '4', label: 'Continents Covered' },
        ].map(s => (
          <div class="border-l-2 border-[#E8690B] pl-4">
            <div class="text-3xl font-bold text-white">{s.value}</div>
            <div class="text-sm text-slate-400 mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="absolute bottom-0 inset-x-0">
      <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 80L1440 80L1440 20C1200 80 960 0 720 40C480 80 240 0 0 20L0 80Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- LOB GRID -->
  <section id="lob" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-14 max-w-2xl">
        <span class="section-label">Insurance Lines</span>
        <h2 class="text-4xl font-bold text-[#00375A]">Seven Lines of Specialty Coverage</h2>
        <p class="text-slate-500 mt-4 text-lg leading-relaxed">
          Each line carries dedicated expertise, market relationships, and a service set calibrated to the specific risk characteristics of that class.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        {lobs.map(lob => (
          <a href={`/services#${lob.id}`}
             class="group bg-white rounded-xl border border-slate-100 shadow-sm hover:shadow-lg hover:border-[#E8690B] transition-all duration-200 p-6 flex flex-col gap-4">
            <div class="text-4xl">{lob.icon}</div>
            <div>
              <h3 class="text-lg font-semibold text-[#00375A] group-hover:text-[#E8690B] transition-colors">{lob.name}</h3>
              <p class="text-xs text-[#E8690B] font-medium mt-0.5">{lob.tagline}</p>
            </div>
            <p class="text-sm text-slate-500 leading-relaxed flex-1">{lob.description.slice(0, 120)}…</p>
            <div class="flex flex-wrap gap-1.5 mt-auto">
              {lob.sectors.slice(0, 2).map(s => (
                <span class="text-xs bg-slate-50 text-slate-500 border border-slate-100 rounded-full px-2.5 py-0.5">{s}</span>
              ))}
            </div>
            <span class="text-xs font-semibold text-[#E8690B] flex items-center gap-1 mt-1">
              View services <span aria-hidden="true">→</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="py-24" style="background:#F4F7FA;">
    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
      <div>
        <span class="section-label">Who We Are</span>
        <h2 class="text-4xl font-bold text-[#00375A] mb-6">An Independent Consulting Firm for Complex Risks</h2>
        <p class="text-slate-600 text-lg leading-relaxed mb-6">
          ktayl-solution was founded on the conviction that large, complex risk programmes deserve more than a standard broking relationship. Our consultants bring deep technical expertise from Lloyd's syndicates, international insurers, and risk engineering firms.
        </p>
        <p class="text-slate-600 leading-relaxed mb-8">
          We operate across the full risk management lifecycle — from initial exposure assessment and programme design, through market placement and negotiation, to ongoing claims advocacy and portfolio analytics.
        </p>
        <div class="grid grid-cols-2 gap-6">
          {[
            { icon: '🎯', title: 'Independent', body: "No insurer ownership. Our advice is free from conflicts of interest." },
            { icon: '🌍', title: 'Global Markets', body: "Access to Lloyd's, Bermuda, European and Asian specialty carriers." },
            { icon: '🔬', title: 'Technical Depth', body: 'Former underwriters, risk engineers, and claims specialists in-house.' },
            { icon: '📋', title: 'Full Lifecycle', body: 'Advisory from exposure audit to claims resolution and renewal.' },
          ].map(v => (
            <div class="flex gap-3">
              <span class="text-2xl">{v.icon}</span>
              <div>
                <div class="font-semibold text-[#00375A] text-sm">{v.title}</div>
                <div class="text-xs text-slate-500 mt-1 leading-relaxed">{v.body}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="relative rounded-2xl overflow-hidden" style="background:linear-gradient(135deg,#00375A,#004D7A); min-height:420px; padding:3rem;">
        <div class="absolute top-4 right-4 opacity-10 text-9xl select-none">⚓</div>
        <div class="relative text-white">
          <div class="text-5xl mb-4">📍</div>
          <h3 class="text-2xl font-bold mb-6">Our Approach</h3>
          <ol class="space-y-5">
            {[
              ['01', 'Exposure Mapping', 'Understand the full risk landscape before touching the market.'],
              ['02', 'Programme Design', 'Structure limits, retentions, and towers tailored to your risk appetite.'],
              ['03', 'Market Placement', 'Negotiate with the right markets. No default panel.'],
              ['04', 'Claims Advocacy', 'Proactive claims management to protect your balance sheet.'],
            ].map(([n, t, b]) => (
              <li class="flex gap-4">
                <span class="text-[#E8690B] font-bold text-sm w-6 shrink-0 mt-0.5">{n}</span>
                <div>
                  <div class="font-semibold text-sm">{t}</div>
                  <div class="text-xs text-slate-300 mt-0.5 leading-relaxed">{b}</div>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- PLATFORM -->
  <section id="platform" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="section-label">Technology Foundation</span>
        <h2 class="text-4xl font-bold text-[#00375A]">Built on Enterprise-Grade Infrastructure</h2>
        <p class="text-slate-500 mt-4 max-w-2xl mx-auto text-lg leading-relaxed">
          Our internal platform runs on a private Kubernetes cluster designed to the same standards as tier-1 financial institutions — high availability, GitOps delivery, end-to-end observability.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-12">
        {[
          { icon: '☸️', title: 'Kubernetes Platform', body: 'k3s cluster on bare-metal, ArgoCD GitOps, automated rollouts with zero-downtime deployments.' },
          { icon: '🔒', title: 'Enterprise SSO', body: 'Authentik identity provider with OIDC, TOTP, and role-based access control across all internal tools.' },
          { icon: '📈', title: 'Full Observability', body: 'Prometheus, Grafana, Loki, and Alertmanager — real-time metrics, logs, and alerting on every service.' },
          { icon: '🛡️', title: 'Private Registry', body: 'Harbor container registry with Trivy scanning — every image verified before deployment.' },
          { icon: '🌐', title: 'Global Access', body: 'Cloudflare Tunnel — all services reachable globally via HTTPS with Cloudflare CDN and TLS termination.' },
          { icon: '💾', title: 'Backup & DR', body: 'Velero daily backups, MinIO object storage, and hourly k3s state snapshots with automated recovery.' },
        ].map(c => (
          <div class="bg-slate-50 rounded-xl p-6 border border-slate-100 hover:border-[#E8690B] transition-colors group">
            <div class="text-3xl mb-3">{c.icon}</div>
            <h3 class="font-semibold text-[#00375A] mb-2 group-hover:text-[#E8690B] transition-colors">{c.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{c.body}</p>
          </div>
        ))}
      </div>

      <div class="flex flex-wrap justify-center gap-3">
        {['k3s', 'ArgoCD', 'Harbor', 'Authentik', 'Prometheus', 'Grafana', 'Loki', 'Longhorn', 'NATS', 'Cloudflare', 'Backstage', 'KEDA'].map(t => (
          <span class="bg-[#00375A] text-white text-xs font-medium px-3 py-1.5 rounded-full">{t}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" style="background:linear-gradient(135deg,#00233A,#00375A);" class="py-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <span class="section-label">Get in Touch</span>
      <h2 class="text-4xl font-bold text-white mb-5">Talk to a Specialist</h2>
      <p class="text-slate-300 text-lg mb-12 leading-relaxed">
        Whether you need to structure a new programme, benchmark existing coverage, or manage a complex claim — we're ready to help.
      </p>
      <form
        action="https://formspree.io/f/placeholder"
        method="POST"
        class="bg-white rounded-2xl p-8 text-left shadow-2xl"
      >
        <div class="grid md:grid-cols-2 gap-5 mb-5">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Full name</label>
            <input type="text" name="name" required placeholder="Jean Dupont"
              class="w-full border border-slate-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#00375A] transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Company</label>
            <input type="text" name="company" placeholder="Your organisation"
              class="w-full border border-slate-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#00375A] transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Email</label>
            <input type="email" name="email" required placeholder="you@company.com"
              class="w-full border border-slate-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#00375A] transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Line of Business</label>
            <select name="lob"
              class="w-full border border-slate-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#00375A] transition-colors text-slate-700">
              <option value="">Select a line…</option>
              {lobs.map(l => <option value={l.id}>{l.name}</option>)}
              <option value="other">Other / Multi-line</option>
            </select>
          </div>
        </div>
        <div class="mb-6">
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Message</label>
          <textarea name="message" rows={4} required placeholder="Describe your risk or enquiry…"
            class="w-full border border-slate-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#00375A] transition-colors resize-none"></textarea>
        </div>
        <button type="submit" class="btn-primary w-full text-center py-3.5 text-base">
          Send Message →
        </button>
        <p class="text-xs text-slate-400 mt-4 text-center">We respond within one business day.</p>
      </form>
    </div>
  </section>

</Layout>
